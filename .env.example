# Discord bot credentials
DISCORD_TOKEN=your-bot-token-here
DISCORD_CLIENT_ID=your-application-id-here

# Optional: register slash commands to a single guild for fast iteration.
# Leave blank in production to register globally.
DISCORD_GUILD_ID=

# Optional: bot owner Discord user id (used for owner-only debug commands later)
OWNER_ID=

# Logging
NODE_ENV=development
LOG_LEVEL=info
